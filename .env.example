# Tinder for Languages - root .env
#
# Copy this file to `.env` and fill in real values.
# Never commit `.env`. A pre-commit hook (gitleaks) is configured to block secrets.

# ---- API keys ---------------------------------------------------------------

# OpenAI - used by backend TTS and sentence validator
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini - used by backend infographic + image generation
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- Server -----------------------------------------------------------------

HOST=0.0.0.0
PORT=8501
ENV=dev
LOG_LEVEL=INFO

# ---- Database (PostgreSQL) --------------------------------------------------
# Set USE_SQLITE=True in backend to skip Postgres and use the bundled SQLite DB.

DB_HOST=localhost
DB_PORT=5433
DB_USER=tinder_user
DB_PASSWORD=change_me
DB_SCHEMA=public
DB_DATABASE=tinder_languages_db

# Recreate schema on startup. WARNING: drops all data.
RECREATE_DB=False
