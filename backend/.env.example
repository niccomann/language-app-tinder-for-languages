# Server Configuration
HOST=0.0.0.0
PORT=8000
ENV=dev
LOG_LEVEL=INFO

# YouTube API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# OpenAI API Configuration (for Sora AI video generation)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USER=tinder_user
DB_PASSWORD=tinder_password
DB_SCHEMA=public
DB_DATABASE=tinder_languages_db

# Set to True to recreate schema on startup (WARNING: deletes all data!)
RECREATE_DB=False
