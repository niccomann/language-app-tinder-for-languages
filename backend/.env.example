# Server Configuration
HOST=0.0.0.0
PORT=8000
ENV=dev
LOG_LEVEL=INFO

# OpenAI API Configuration (for TTS and grammar validation)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini API Configuration (for infographic generation - Nano Banana Pro)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Database Configuration
USE_SQLITE=True

# PostgreSQL alternative. Set USE_SQLITE=False before using these values.
DB_HOST=localhost
DB_PORT=5433
DB_USER=tinder_user
DB_PASSWORD=tinder_password
DB_SCHEMA=public
DB_DATABASE=tinder_languages_db

# Set to True to recreate schema on startup (WARNING: deletes all data!)
RECREATE_DB=False
