apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: tinder-languages
type: Opaque
stringData:
  # OpenAI API key (optional - for TTS and AI features)
  openai-api-key: "YOUR_OPENAI_API_KEY_HERE"
  
  # Database password (only needed if using PostgreSQL instead of SQLite)
  # db-password: "YOUR_SECURE_PASSWORD_HERE"
  
# Note: The current deployment uses SQLite (USE_SQLITE=true in backend env)
# For production with PostgreSQL, uncomment db-password and update backend-deployment.yaml
