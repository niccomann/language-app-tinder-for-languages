# =============================================================================
# TINDER FOR LANGUAGES - SECRETS CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# =============================================================================

# -----------------------------------------------------------------------------
# AWS CREDENTIALS (Required for deployment)
# Get from: AWS Console → IAM → Users → Security credentials
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=664111151564

# -----------------------------------------------------------------------------
# DATABASE (For EKS deployment - uses SQLite by default)
# For production, consider using AWS RDS
# -----------------------------------------------------------------------------
USE_SQLITE=true
# If using PostgreSQL:
# DB_HOST=your-rds-endpoint.amazonaws.com
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_secure_password_here
# DB_DATABASE=tinder_languages
# DB_SCHEMA=public

# -----------------------------------------------------------------------------
# APPLICATION SECRETS
# -----------------------------------------------------------------------------
SECRET_KEY=your_app_secret_key_here
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------------------------
# ECR REPOSITORIES (auto-generated)
# -----------------------------------------------------------------------------
ECR_BACKEND_REPO=664111151564.dkr.ecr.eu-central-1.amazonaws.com/tinder-languages-backend
ECR_FRONTEND_REPO=664111151564.dkr.ecr.eu-central-1.amazonaws.com/tinder-languages-frontend

# -----------------------------------------------------------------------------
# CLUSTER CONFIGURATION
# -----------------------------------------------------------------------------
CLUSTER_NAME=tinder-languages-cluster
NAMESPACE=tinder-languages
